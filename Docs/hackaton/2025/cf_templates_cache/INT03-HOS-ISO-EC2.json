"AWSTemplateFormatVersion: '2010-09-09'\nResources:\n  LaunchTemplate:\n    Type: 'AWS::EC2::LaunchTemplate'\n    Properties:\n      LaunchTemplateName: !Sub '${AWS::StackName}-LaunchTemplate'\n      TagSpecifications:\n          - ResourceType: \"launch-template\"\n            Tags:\n            - Key: Name\n              Value: 'hos-iso'\n            - Key: environment\n              Value: 'INT'\n            - Key: app_environment_id\n              Value: 'int03'\n            - Key: automation\n              Value: 'true'\n            - Key: bootstrap_s3\n              Value: 'true'\n            - Key: app_group\n              Value: \"inventory-synchronization-service\"\n            - Key: org_domain\n              Value: \"external-integrations\"\n            - Key: service_domain\n              Value: \"real-time-data-distribution\"\n            - Key: app_name\n              Value: \"hos-iso\"\n      LaunchTemplateData:\n        MetadataOptions:\n          HttpTokens: 'optional'\n          HttpEndpoint: 'enabled'\n        TagSpecifications:\n          - ResourceType: \"volume\"\n            Tags:\n            - Key: Name\n              Value: 'hos-iso'\n            - Key: environment\n              Value: 'INT'\n            - Key: app_environment_id\n              Value: 'int03'\n            - Key: automation\n              Value: 'true'\n            - Key: bootstrap_s3\n              Value: 'true'\n            - Key: app_group\n              Value: \"inventory-synchronization-service\"\n            - Key: org_domain\n              Value: \"external-integrations\"\n            - Key: service_domain\n              Value: \"real-time-data-distribution\"\n            - Key: app_name\n              Value: \"hos-iso\"\n          - ResourceType: \"network-interface\"\n            Tags:\n            - Key: Name\n              Value: 'hos-iso'\n            - Key: environment\n              Value: 'INT'\n            - Key: app_environment_id\n              Value: 'int03'\n            - Key: automation\n              Value: 'true'\n            - Key: app_group\n              Value: \"inventory-synchronization-service\"\n            - Key: org_domain\n              Value: \"external-integrations\"\n            - Key: service_domain\n              Value: \"real-time-data-distribution\"\n            - Key: app_name\n              Value: \"hos-iso\"\n        IamInstanceProfile: \n          Name: 'int-systems'\n        InstanceType: 't3.small'\n        ImageId: 'resolve:ssm:/st/app/cloud-platform/core/ami2'\n        BlockDeviceMappings:\n        - DeviceName: /dev/sda1\n          Ebs:\n            DeleteOnTermination: true\n            VolumeSize: 8\n            VolumeType: gp3\n        - DeviceName: '/dev/xvdb'\n          Ebs:\n            DeleteOnTermination: true\n            VolumeSize: 5\n            VolumeType: gp3\n        SecurityGroupIds:\n          - 'sg-321c6155'\n        Monitoring:\n          Enabled: true\n        UserData: \n          Fn::Base64: !Sub |\n            #!/bin/bash -x\n\n              echo ENVIRONMENT=INT >> /tmp/bootstrap.config\n              echo GIT_DEPLOYMENT_REPO_URL=git@bitbucket.org:skytouchtechnology/deployment4.git >> /tmp/bootstrap.config\n              echo GIT_DEPLOYMENT_BRANCH=master >> /tmp/bootstrap.config\n              echo GIT_DEPLOYMENT_VARS_REPO_URL=git@bitbucket.org:skytouchtechnology/st-vars.git >> /tmp/bootstrap.config\n              echo GIT_DEPLOYMENT_VARS_BRANCH=master >> /tmp/bootstrap.config\n              echo APP_ENVIRONMENT_ID=int03 >> /tmp/bootstrap.config\n              echo APP_NAME=hos-iso >> /tmp/bootstrap.config\n              echo APP_VERSION= >> /tmp/bootstrap.config\n              echo CLOUD_CONFIG_REPO_BRANCH=master >> /tmp/bootstrap.config\n\n              export GIT_SSH_COMMAND='ssh -o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no'\n              mkdir /tmp/st-infra/\n\n              aws s3 cp s3://st-vars-int/id_rsa /root/.ssh/id_rsa\n              chmod 400 /root/.ssh/id_rsa\n\n              aws s3 cp s3://skytouch-downloads/bootstrap/ /tmp/st-infra/ --recursive\n              cp /tmp/st-infra/bootstrap-scripts/bootstrap.sh /tmp/bootstrap.sh\n              rm -rf /tmp/st-infra/*\n              stdbuf -i0 -o0 -e0 bash /tmp/bootstrap.sh > /tmp/bootstrap.log\n              EXIT_CODE=$?; \n              STATUS=$([ $EXIT_CODE -eq 0 ] && echo \"SUCCESS\" || echo \"FAILURE\"); \n              UNIQUE_ID=$(curl -s http://169.254.169.254/latest/meta-data/instance-id); \n              aws cloudformation signal-resource \\\n               --stack-name ${AWS::StackName} \\\n               --logical-resource-id \"AutoScaleGroup\" \\\n               --status \"$STATUS\" --region ${AWS::Region} \\\n               --unique-id \"$UNIQUE_ID\"\n\n\n  AutoScaleGroup:\n    Type: AWS::AutoScaling::AutoScalingGroup\n    Properties:\n      VPCZoneIdentifier:\n        - 'subnet-02fbd67f067f3bb9a'\n        - 'subnet-08285b36674fdff0b'\n      DesiredCapacity: '1'\n      CapacityRebalance: true\n      Cooldown: '600'\n      MinSize: '1'\n      MaxSize: '1'\n      LaunchTemplate:\n        LaunchTemplateId: !Ref 'LaunchTemplate'\n        Version: !GetAtt LaunchTemplate.LatestVersionNumber\n      \n      HealthCheckType: 'ELB'\n      HealthCheckGracePeriod: '1200'\n      Tags:\n        - Key: Name\n          Value: 'hos-iso'\n          PropagateAtLaunch: true\n        - Key: environment\n          Value: 'INT'\n          PropagateAtLaunch: true\n        - Key: app_environment_id\n          Value: 'int03'\n          PropagateAtLaunch: true\n        - Key: automation\n          Value: 'true'\n          PropagateAtLaunch: true\n        - Key: bootstrap_s3\n          Value: 'true'\n          PropagateAtLaunch: true\n        - Key: app_group\n          Value: \"inventory-synchronization-service\"\n          PropagateAtLaunch: true\n        - Key: org_domain\n          Value: \"external-integrations\"\n          PropagateAtLaunch: true\n        - Key: service_domain\n          Value: \"real-time-data-distribution\"\n          PropagateAtLaunch: true\n        - Key: app_name\n          Value: \"hos-iso\"\n          PropagateAtLaunch: true\n        # Only if NightShutdown is defined and value is not false\n        - Key: night_shutdown\n          Value: 'on'\n          PropagateAtLaunch: true\n        - Key: morning_start_group\n          Value: '4'\n          PropagateAtLaunch: true\n    CreationPolicy:\n      ResourceSignal:\n        Count: 1\n        Timeout: PT20M\n  \n\n\nOutputs:\n  AsgName:\n    Value: !Ref 'AutoScaleGroup'\n  "